---
import '../styles/global.css';
import { Toaster } from 'sonner';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Stelling Secure | Desarrollo Web y Seguridad Web para PYMEs en Valencia",
  description = "Stelling Secure: agencia de desarrollo web y seguridad web para PYMEs en Valencia. Webs rápidas, seguras y orientadas a resultados. Auditoría web gratuita."
} = Astro.props;

// El nonce es generado por el middleware en cada request.
// Astro lo lee de Astro.locals.cspNonce y lo inyecta automáticamente
// en todos los <script> de hidratación (client:load, client:visible, etc.).
const nonce = Astro.locals.cspNonce;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alfredo Stelling Bell" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#050508" />
    <link rel="canonical" href="https://stellingsecure.com/" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://stellingsecure.com/" />
    <meta property="og:title" content="Stelling Secure | Desarrollo Web y Seguridad Web Valencia" />
    <meta property="og:description" content="Construimos webs rápidas y seguras para PYMEs en Valencia." />
    <meta property="og:image" content="https://stellingsecure.com/og-image.jpg" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Stelling Secure" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Stelling Secure | Desarrollo Web y Seguridad Web Valencia" />
    <meta name="twitter:description" content="Webs rápidas y seguras para PYMEs en Valencia." />
    <meta name="twitter:image" content="https://stellingsecure.com/og-image.jpg" />
  </head>
  <body>
    <div style="position:fixed; width:600px; height:600px; background:rgba(123,79,255,0.07); border-radius:50%; filter:blur(120px); top:-200px; right:-100px; pointer-events:none; z-index:0;"></div>
    <div style="position:fixed; width:400px; height:400px; background:rgba(0,229,255,0.05); border-radius:50%; filter:blur(120px); bottom:20%; left:-100px; pointer-events:none; z-index:0;"></div>
    <Toaster client:load richColors position="bottom-right" />
    <slot />
  </body>
</html>